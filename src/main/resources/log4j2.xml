<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN" monitorInterval="30">
	<Properties>
		<Property name="LOG_PATTERN">%d{yyyy-MM-dd'T'HH:mm:ss.SSSZ} %p %m%n
		</Property>
		<Property name="APP_LOG_ROOT">c:/temp</Property>
	</Properties>

	<Appenders>
		<Console name="Console" target="SYSTEM_OUT" follow="true">
			<PatternLayout pattern="${LOG_PATTERN}" />
		</Console>
		<RollingFile name="appLog"
			fileName="${APP_LOG_ROOT}/HR_SERVICE/application.log"
			filePattern="${APP_LOG_ROOT}/HR_SERVICE/application-%d{yyyy-MM-dd}-%i.log">
			<PatternLayout pattern="${LOG_PATTERN}" />
			<!-- rollover on startup, daily and when the file reaches 10 MegaBytes -->
			<OnStartupTriggeringPolicy />
			<SizeBasedTriggeringPolicy size="10 MB" />
			<TimeBasedTriggeringPolicy />
			<DefaultRolloverStrategy max="1" />
		</RollingFile>
	</Appenders>

	<Loggers>
		<Logger name="com.acn.nemo" additivity="false">
			<AppenderRef ref="appLog" />
			<AppenderRef ref="Console" />
		</Logger>
		<Root level="info">
			<AppenderRef ref="Console" />
			<AppenderRef ref="appLog" />
		</Root>
	</Loggers>
</Configuration>